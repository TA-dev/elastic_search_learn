{"ast":null,"code":"export default {\n  name: \"StarsBackground\",\n  data() {\n    return {\n      stars: [],\n      numberOfStars: 50,\n      starColors: [\"#00b4ff\", \"#ffffff\"]\n    };\n  },\n  mounted() {\n    this.generateStars();\n  },\n  methods: {\n    generateStars() {\n      this.stars = Array.from({\n        length: this.numberOfStars\n      }, (_, index) => {\n        const duration = Math.random() * 40 + 20; // Random duration between 30-45s\n        return {\n          id: index,\n          x: Math.random() * 100,\n          y: Math.random() * 100,\n          size: Math.random() * 3.5 + 0.5,\n          opacity: Math.random() * 0.3 + 0.7,\n          delay: -Math.random() * duration,\n          // Negative delay to start midway\n          duration: duration,\n          color: this.starColors[Math.floor(Math.random() * this.starColors.length)]\n        };\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","stars","numberOfStars","starColors","mounted","generateStars","methods","Array","from","length","_","index","duration","Math","random","id","x","y","size","opacity","delay","color","floor"],"sources":["C:\\Users\\talam\\OneDrive\\Documents\\GitHub\\elastic_search_learn\\ElasticFinalProject\\frontend\\src\\components\\StarsBackground.vue"],"sourcesContent":["<template>\n  <div class=\"stars-container\">\n    <div\n      v-for=\"star in stars\"\n      :key=\"star.id\"\n      class=\"star\"\n      :style=\"{\n        left: `${star.x}%`,\n        top: `${star.y}%`,\n        width: `${star.size}px`,\n        height: `${star.size}px`,\n        opacity: star.opacity,\n        transform: `translateY(${star.offset}px)`,\n        animationDuration: `${star.duration}s`,\n        animationDelay: `${star.delay}s`,\n        backgroundColor: star.color,\n      }\"\n    ></div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"StarsBackground\",\n  data() {\n    return {\n      stars: [],\n      numberOfStars: 50,\n      starColors: [\"#00b4ff\", \"#ffffff\"],\n    };\n  },\n  mounted() {\n    this.generateStars();\n  },\n  methods: {\n    generateStars() {\n      this.stars = Array.from({ length: this.numberOfStars }, (_, index) => {\n        const duration = Math.random() * 40 + 20; // Random duration between 30-45s\n        return {\n          id: index,\n          x: Math.random() * 100,\n          y: Math.random() * 100,\n          size: Math.random() * 3.5 + 0.5,\n          opacity: Math.random() * 0.3 + 0.7,\n          delay: -Math.random() * duration, // Negative delay to start midway\n          duration: duration,\n          color:\n            this.starColors[Math.floor(Math.random() * this.starColors.length)],\n        };\n      });\n    },\n  },\n};\n</script>\n\n<style scoped>\n.stars-container {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100vh;\n  background-color: #080e1a;\n  overflow: hidden;\n  z-index: -1;\n}\n\n.star {\n  position: absolute;\n  border-radius: 50%;\n  animation: moveUpward linear infinite;\n}\n\n@keyframes moveUpward {\n  from {\n    transform: translateY(100vh);\n  }\n  to {\n    transform: translateY(-100vh);\n  }\n}\n</style>\n"],"mappings":"AAsBA,eAAe;EACbA,IAAI,EAAE,iBAAiB;EACvBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,EAAE;MACTC,aAAa,EAAE,EAAE;MACjBC,UAAU,EAAE,CAAC,SAAS,EAAE,SAAS;IACnC,CAAC;EACH,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,aAAa,CAAC,CAAC;EACtB,CAAC;EACDC,OAAO,EAAE;IACPD,aAAaA,CAAA,EAAG;MACd,IAAI,CAACJ,KAAI,GAAIM,KAAK,CAACC,IAAI,CAAC;QAAEC,MAAM,EAAE,IAAI,CAACP;MAAc,CAAC,EAAE,CAACQ,CAAC,EAAEC,KAAK,KAAK;QACpE,MAAMC,QAAO,GAAIC,IAAI,CAACC,MAAM,CAAC,IAAI,EAAC,GAAI,EAAE,EAAE;QAC1C,OAAO;UACLC,EAAE,EAAEJ,KAAK;UACTK,CAAC,EAAEH,IAAI,CAACC,MAAM,CAAC,IAAI,GAAG;UACtBG,CAAC,EAAEJ,IAAI,CAACC,MAAM,CAAC,IAAI,GAAG;UACtBI,IAAI,EAAEL,IAAI,CAACC,MAAM,CAAC,IAAI,GAAE,GAAI,GAAG;UAC/BK,OAAO,EAAEN,IAAI,CAACC,MAAM,CAAC,IAAI,GAAE,GAAI,GAAG;UAClCM,KAAK,EAAE,CAACP,IAAI,CAACC,MAAM,CAAC,IAAIF,QAAQ;UAAE;UAClCA,QAAQ,EAAEA,QAAQ;UAClBS,KAAK,EACH,I