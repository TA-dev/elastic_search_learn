{"ast":null,"code":"export default {\n  name: \"ImagePopover\",\n  props: {\n    show: Boolean,\n    imageUrl: String,\n    imageTitle: String\n  },\n  mounted() {\n    document.addEventListener(\"keydown\", this.handleEscape);\n  },\n  beforeUnmount() {\n    document.removeEventListener(\"keydown\", this.handleEscape);\n  },\n  methods: {\n    handleEscape(e) {\n      if (e.key === \"Escape\" && this.show) {\n        this.$emit(\"close\");\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","props","show","Boolean","imageUrl","String","imageTitle","mounted","document","addEventListener","handleEscape","beforeUnmount","removeEventListener","methods","e","key","$emit"],"sources":["C:\\Users\\talam\\OneDrive\\Documents\\GitHub\\elastic_search_learn\\ElasticFinalProject\\frontend\\src\\components\\ImagePopover.vue"],"sourcesContent":["<template>\n  <Transition name=\"fade\">\n    <div v-if=\"show\" class=\"popover-overlay\" @click=\"$emit('close')\">\n      <Transition name=\"scale\">\n        <div class=\"popover-content\" v-if=\"show\">\n          <div class=\"button-container\">\n            <button\n              class=\"action-button close-button\"\n              @click.stop=\"$emit('close')\"\n              v-tooltip.top=\"'Close'\"\n            >\n              <i class=\"fas fa-times\"></i>\n            </button>\n          </div>\n          <img\n            :src=\"imageUrl\"\n            :alt=\"imageTitle\"\n            class=\"popover-image\"\n            @click.stop\n          />\n        </div>\n      </Transition>\n    </div>\n  </Transition>\n</template>\n\n<script>\nexport default {\n  name: \"ImagePopover\",\n  props: {\n    show: Boolean,\n    imageUrl: String,\n    imageTitle: String,\n  },\n  mounted() {\n    document.addEventListener(\"keydown\", this.handleEscape);\n  },\n  beforeUnmount() {\n    document.removeEventListener(\"keydown\", this.handleEscape);\n  },\n  methods: {\n    handleEscape(e) {\n      if (e.key === \"Escape\" && this.show) {\n        this.$emit(\"close\");\n      }\n    },\n  },\n};\n</script>\n\n<style scoped>\n.popover-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  background: rgba(0, 0, 0, 0.9);\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  z-index: 1000;\n}\n\n.popover-content {\n  position: relative;\n  max-width: 90vw;\n  max-height: 100vh;\n  padding-top: 3rem;\n}\n\n.popover-image {\n  max-width: 100%;\n  max-height: 90vh;\n  object-fit: contain;\n  border: 2px solid var(--primary-color);\n  box-shadow: 0 0 1.25rem rgba(234, 94, 19, 0.3);\n}\n\n.button-container {\n  position: absolute;\n  top: 0rem;\n  right: 0rem;\n  display: flex;\n  z-index: 1;\n}\n\n.close-button {\n  background: rgba(234, 94, 19, 0.8);\n}\n\n.close-button:hover {\n  background: rgba(255, 111, 30, 0.9);\n  transform: scale(1.1);\n}\n\n/* Fade transition */\n.fade-enter-active,\n.fade-leave-active {\n  transition: opacity 0.3s ease;\n}\n\n.fade-enter-from,\n.fade-leave-to {\n  opacity: 0;\n}\n\n/* Scale transition */\n.scale-enter-active,\n.scale-leave-active {\n  transition: transform 0.3s ease;\n}\n\n.scale-enter-from,\n.scale-leave-to {\n  transform: scale(0.9);\n}\n</style>\n"],"mappings":"AA2BA,eAAe;EACbA,IAAI,EAAE,cAAc;EACpBC,KAAK,EAAE;IACLC,IAAI,EAAEC,OAAO;IACbC,QAAQ,EAAEC,MAAM;IAChBC,UAAU,EAAED;EACd,CAAC;EACDE,OAAOA,CAAA,EAAG;IACRC,QAAQ,CAACC,gBAAgB,CAAC,SAAS,EAAE,IAAI,CAACC,YAAY,CAAC;EACzD,CAAC;EACDC,aAAaA,CAAA,EAAG;IACdH,QAAQ,CAACI,mBAAmB,CAAC,SAAS,EAAE,IAAI,CAACF,YAAY,CAAC;EAC5D,CAAC;EACDG,OAAO,EAAE;IACPH,YAAYA,CAACI,CAAC,EAAE;MACd,IAAIA,CAAC,CAACC,GAAE,KAAM,QAAO,IAAK,IAAI,CAACb,IAAI,EAAE;QACnC,IAAI,CAACc,KAAK,CAAC,OAAO,CAAC;MACrB;IACF;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}